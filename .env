# ── KPS Identity API — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values before starting.

# Strong random API key — generate with: openssl rand -hex 32

API_KEY=a3f8c2e1d4b7a9f0e3c6d2b5a8f1c4e7d0b3a6f9c2e5d8b1a4f7c0e3d6b9a2

# Port to listen on (default: 3000)
PORT=3000

# NVI KPS endpoint (default is the public NVI address)
# Override for test/mock environments
KPS_ENDPOINT=https://tckimlik.nvi.gov.tr/Service/KPSPublic.asmx

# KPS call timeout in milliseconds (default: 8000)
KPS_TIMEOUT_MS=8000

# Directory for audit logs (default: ./logs)
LOG_DIR=./logs
